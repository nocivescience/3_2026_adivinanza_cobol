IDENTIFICATION DIVISION.
PROGRAM-ID. ADIVINA-SQL-GEN.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ARCHIVO-SQL ASSIGN TO "insertar.sql"
    ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD ARCHIVO-SQL.
01 REGISTRO-ARCHIVO    PIC X(100).

WORKING-STORAGE SECTION.
01 NUMERO-SECRETO      PIC 9(2).
01 SEMILLA             PIC 9(9).
01 INTENTO             PIC 9(2) VALUE 99.
01 NOMBRE-JUGADOR      PIC A(20).
01 CONTADOR-INTENTOS   PIC 9(3) VALUE 0.
*> Esta es la variable que faltaba
01 BUFFER-SQL          PIC X(100). 

PROCEDURE DIVISION.
    ACCEPT SEMILLA FROM TIME.
    COMPUTE NUMERO-SECRETO = FUNCTION MOD(FUNCTION RANDOM(SEMILLA) * 100, 100).
    
    DISPLAY "Cual es tu nombre? " WITH NO ADVANCING
    ACCEPT NOMBRE-JUGADOR
    
    PERFORM UNTIL INTENTO = NUMERO-SECRETO
        ADD 1 TO CONTADOR-INTENTOS
        DISPLAY "Tu intento: " WITH NO ADVANCING
        ACCEPT INTENTO
        
        IF INTENTO < NUMERO-SECRETO
            DISPLAY "Muy bajo."
        ELSE IF INTENTO > NUMERO-SECRETO
            DISPLAY "Muy alto."
        END-IF
    END-PERFORM.

    *> Generar la instrucción SQL en el buffer
    STRING "INSERT INTO adivinanzas (nombre, numero_secreto, intentos) VALUES ('"
           FUNCTION TRIM(NOMBRE-JUGADOR) "', "
           NUMERO-SECRETO ", "
           CONTADOR-INTENTOS ");"
           DELIMITED BY SIZE INTO BUFFER-SQL
    END-STRING.

    *> Escribir el contenido del buffer en el archivo
    *> OPEN OUTPUT ARCHIVO-SQL
    *> MOVE BUFFER-SQL TO REGISTRO-ARCHIVO
    *> WRITE REGISTRO-ARCHIVO
    *> CLOSE ARCHIVO-SQL

    OPEN EXTEND ARCHIVO-SQL
    MOVE BUFFER-SQL TO REGISTRO-ARCHIVO
    WRITE REGISTRO-ARCHIVO
    CLOSE ARCHIVO-SQL

    DISPLAY "Archivo 'insertar.sql' generado con exito.".
    STOP RUN.
